# PainScan Environment Variables
# Copy this file to .env.local for local development
# Add these as Environment Variables in your Vercel project dashboard

# OpenAI API Key (get from platform.openai.com)
OPENAI_API_KEY=sk-...

# Stripe Secret Key (get from dashboard.stripe.com — use TEST key first!)
# Test: sk_test_...
# Live: sk_live_...
STRIPE_SECRET_KEY=sk_test_...

# Optional: Your domain (used for CORS and emails)
SITE_URL=https://painscan.fyi
